DATABASE_URL="postgresql://postgres:postgres@localhost:5432/kiel_beer_index?schema=public"

# Public base URL of the app (used to build email links).
# Defaults to the origin of the incoming request when not set.
APP_URL="https://example.com"

# SMTP configuration for sending transactional email.
# When SMTP_HOST is not set, verification links are logged to stdout instead of sent.
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="user@example.com"
SMTP_PASS="password"
SMTP_FROM="noreply@example.com"

# GitHub Personal Access Token for fetching review app deployments.
# Requires `repo:read` scope (or just `public_repo` for public repos).
# When not set, the Review Apps admin page will show an error.
GITHUB_TOKEN=""
